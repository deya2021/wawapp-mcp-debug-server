{
  "name": "wawapp-mcp-debug-server",
  "version": "1.0.0",
  "description": "Read-only MCP debugging server for WawApp Firebase/Flutter ecosystem",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:unit": "jest tests/*.test.ts --testPathIgnorePatterns=golden-snapshots.test.ts",
    "test:golden": "jest tests/golden-snapshots.test.ts",
    "test:yaml": "jest tests/scenario-yaml-validation.test.ts",
    "verify": "npm run build && npm run test:yaml && npm run test:unit && npm run test:golden",
    "verify:quick": "tsc --noEmit && npm run test:yaml"
  },
  "keywords": ["mcp", "firebase", "debugging", "wawapp"],
  "author": "WawApp Development Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "firebase-admin": "^12.0.0",
    "@google-cloud/logging": "^11.0.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "date-fns": "^3.0.6",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
